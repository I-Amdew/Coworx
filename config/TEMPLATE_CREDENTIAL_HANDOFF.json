{
  "site": "example.com",
  "account_label": "approved_account_label",
  "login_url": "https://example.com/login",
  "credential_source": "local_env_or_private_file",
  "credential_source_reference": "env names, private file path, keychain label, password-manager item, local skill ref, oauth connector, api connector, or vault handle only",
  "coworx_credential_memory": "available_via_scripts/coworx_local_secret_store.mjs_and_non_secret_reference_packets",
  "chrome_password_manager_is_not_coworx_memory": true,
  "credential_capture": "interactive_hidden_tty_or_env_keychain_password_manager_vault",
  "credential_persistence": "allowed_when_explicitly_delegated_to_ignored_private_secret_store",
  "username_env": "COWORX_EXAMPLE_USERNAME",
  "password_env": "COWORX_EXAMPLE_PASSWORD",
  "mfa_answers_env": "COWORX_EXAMPLE_MFA_ANSWERS_JSON",
  "mfa_policy": "user_present_approved_connector_or_explicitly_delegated_local_runtime_handoff_only",
  "mfa_secrets_policy": "do_not_store_totp_seeds_backup_codes_recovery_codes_or_security_answers",
  "allowed_actions": [
    "login",
    "navigate_approved_workspace",
    "read_approved_content",
    "create_draft",
    "update_reversible_items",
    "send_or_submit_only_when_delegated"
  ],
  "blocked_actions": [
    "change_password",
    "change_security_settings",
    "change_payment_settings",
    "export_credentials",
    "export_cookies",
    "perform_account_recovery",
    "store_totp_seeds",
    "store_backup_codes",
    "store_recovery_codes",
    "store_security_answers"
  ],
  "redaction_required": true,
  "screenshot_policy": "disable_or_redact_during_secret_entry",
  "trace_policy": "disable_or_redact_during_secret_entry"
}
