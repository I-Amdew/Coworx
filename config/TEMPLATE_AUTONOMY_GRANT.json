{
  "grant_name": "Example Routine Scheduling",
  "site_or_app": "Example Calendar",
  "account_label": "work",
  "login_method": "approved_connector_or_browser_profile",
  "allowed_without_extra_approval": [
    "read_calendar",
    "create_follow_up_meetings_from_user_instruction",
    "copy_attendees_from_user_named_source_meeting"
  ],
  "credentialed_action_gate": {
    "required_for_level_3_and_4": true,
    "gate_script": "scripts/coworx_autonomous_action_gate.mjs",
    "approved_domains": [
      "calendar.example.com"
    ],
    "allowed_credential_sources": [
      "existing_session",
      "password_manager",
      "browser_autofill",
      "os_keychain",
      "private_file",
      "local_env",
      "local_skill_ref",
      "oauth_connector",
      "api_connector",
      "vault_handle"
    ],
    "secret_values_must_remain_local": true
  },
  "stage_for_approval": [
    "invite_uncertain_attendees",
    "delete_events",
    "send_sensitive_external_description"
  ],
  "always_pause_or_block": [
    "payment",
    "account_security",
    "password_change",
    "credential_export",
    "identity_verification",
    "academic_submission"
  ],
  "external_notifications_allowed": false,
  "final_send_submit_allowed": false,
  "guests_or_recipients_may_be_added": false,
  "data_allowed": [
    "task_relevant_calendar_data"
  ],
  "data_to_avoid": [
    "secrets",
    "unrelated_private_data"
  ],
  "evidence_required": [
    "action_result",
    "created_or_updated_object_id",
    "timestamp"
  ],
  "review_or_expiration": "YYYY-MM-DD or one_task"
}
