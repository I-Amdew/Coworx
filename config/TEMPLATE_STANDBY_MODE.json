{
  "version": 1,
  "standby_mode": {
    "enabled_by_default": true,
    "trigger_phrases": [
      "standby mode",
      "dispatch mode",
      "keep checking",
      "check every 5 minutes",
      "keep working and text me if you need me",
      "run this in standby",
      "continue in the background while this chat/session is active"
    ],
    "default_interval_minutes": 5,
    "default_max_runtime_hours": 6,
    "prevent_duplicate_loops": true,
    "state_path": ".coworx-private/standby/state.json",
    "config_path": ".coworx-private/standby/config.json",
    "status_path": ".coworx-private/standby/status.md",
    "events_path": ".coworx-private/standby/events.ndjson",
    "outbox_path": ".coworx-private/standby/outbox.ndjson",
    "inbox_path": ".coworx-private/standby/inbox.ndjson",
    "inbox_dir": ".coworx-private/standby/inbox/",
    "task_queue_dir": ".coworx-private/standby/tasks/"
  },
  "conversation_style": {
    "mode": "dispatch_thread",
    "quick_acknowledgement": true,
    "kickoff_message": true,
    "milestone_updates_only": true,
    "keep_checking_inbound_while_working": true,
    "no_permission_nagging": true,
    "use_computer_use_notifier_when_configured": true,
    "default_update_shape": [
      "acknowledge the task and what Coworx is starting",
      "say the task is kicked off and list concrete work items when useful",
      "send heads-up only for real blockers or local-only manual steps",
      "send done message with outputs, evidence, staged actions, and remaining user needs"
    ]
  },
  "dispatch_setup": {
    "first_time_setup_required_for_remote_channels": true,
    "approved_channel_label": "private_local_status_file_or_configured_channel_label",
    "approved_account_or_sender_label": "non_secret_label_only",
    "inbound_scope": "new_task_packets_only_until_director_review",
    "remote_replies_can_approve_existing_actions": false,
    "remote_replies_can_create_task_packets": true,
    "max_remote_action_level": 2,
    "approval_command_shape": "approve ACTION_ID",
    "private_config_path": ".coworx-private/standby/config.json",
    "private_outbox_path": ".coworx-private/standby/outbox.ndjson",
    "private_inbox_path": ".coworx-private/standby/inbox.ndjson",
    "private_task_queue_path": ".coworx-private/standby/tasks/",
    "required_setup_questions": [
      "Where should meaningful updates be sent?",
      "Which account, sender, channel, webhook, connector, browser profile, or app route is approved?",
      "May inbound replies approve existing staged non-protected actions, create task packets, both, or neither?",
      "What is the maximum remote action level?",
      "What exact approval command should be accepted?",
      "Should normal cycles stay quiet or send verbose updates?"
    ],
    "never_store_in_public_files": [
      "webhook_urls",
      "phone_numbers",
      "account_identifiers",
      "private_message_bodies",
      "tokens",
      "cookies",
      "credentials"
    ]
  },
  "computer_use_dispatch": {
    "immediate_check_when_configured": true,
    "queue_state_dir": ".coworx-private/computer-use",
    "gui_only_channel_types": [
      "messages_or_imessage",
      "messages_or_imessage_if_available",
      "imessage",
      "gui_messaging_app"
    ],
    "required_locks": [
      "computer_app:Messages",
      "desktop_resource:active_window_focus",
      "account_workflow:approved-standby-dispatch-channel"
    ],
    "one_agent_per_app_at_a_time": true,
    "claim_requires": [
      "queued_or_acquired_lease_id",
      "Computer Use state/action evidence",
      "approved channel/thread verification",
      "lease release evidence"
    ],
    "lease_blocked_behavior": "record_wait_item_and_retry_next_cycle",
    "vague_inbound_task_behavior": "store_private_packet_and_queue_clarification"
  },
  "notifications": {
    "first_time_setup_required": true,
    "default_method": "local_status_file",
    "supported_methods": [
      "discord_private_channel_or_webhook",
      "desktop_notification",
      "messages_or_imessage_if_available",
      "sms_or_email_if_later_configured",
      "local_status_file_only"
    ],
    "notify_only_for": [
      "standby_started",
      "standby_stopped",
      "task_completed",
      "milestone_reached",
      "blocker",
      "approval_needed",
      "login_needed",
      "outputs_ready",
      "max_runtime_reached"
    ],
    "quiet_cycles": true,
    "verbose_mode": false,
    "outbound_notification_targets": [
      {
        "id": "local_status_file",
        "type": "local_status_file",
        "enabled": true,
        "path": ".coworx-private/standby/status.md",
        "stores_private_data": false
      },
      {
        "id": "local_outbox_file",
        "type": "local_outbox_file",
        "enabled": true,
        "path": ".coworx-private/standby/outbox.ndjson",
        "stores_private_data": false,
        "purpose": "Queue meaningful messages for an approved notifier lane such as desktop notification, Discord, Messages/iMessage, or SMS/email."
      }
    ],
    "inbound_task_sources": [
      {
        "id": "local_inbox_file",
        "type": "local_inbox_file",
        "enabled": true,
        "path": ".coworx-private/standby/inbox.ndjson",
        "private": true
      },
      {
        "id": "local_inbox_directory",
        "type": "local_inbox_directory",
        "enabled": true,
        "path": ".coworx-private/standby/inbox/",
        "private": true
      }
    ],
    "queued_task_storage": [
      {
        "id": "private_standby_task_queue",
        "type": "local_task_queue_directory",
        "enabled": true,
        "path": ".coworx-private/standby/tasks/",
        "purpose": "Store inbound new tasks for Director review while the active standby task continues."
      }
    ],
    "adapter_status": {
      "local_status_file": "always_available",
      "local_outbox_file": "always_available",
      "desktop_notification": "requires_local_os_permission",
      "messages_or_imessage_if_available": "requires_Computer_Use_action_request_and_app_lock",
      "discord_private_channel_or_webhook": "requires_private_webhook_or_connector_config",
      "sms_or_email_if_later_configured": "requires_private_adapter_config"
    }
  },
  "temporary_waits": {
    "private_wait_dir": ".coworx-private/standby/waits/",
    "default_interval_minutes": 5,
    "minimum_interval_minutes": 1,
    "use_codex_automations_when_available": true,
    "temporary_automation_cleanup": "delete_disable_or_mark_retired_when_done",
    "release_locks_while_waiting": true,
    "required_fields": [
      "directive_id",
      "condition",
      "next_check_time",
      "interval",
      "max_runtime_or_expiration",
      "owner_thread",
      "resource_lock",
      "private_state_path",
      "cleanup_action"
    ]
  },
  "safety": {
    "use_existing_coworx_authority_model": true,
    "permission_prompt_policy": {
      "remote_reply_can_approve": [
        "ordinary_Level_1_to_4_non_protected_actions_already_recorded_in_the_active_directive"
      ],
      "local_only_manual_action_needed": [
        "macOS_privacy_permission_prompt",
        "Codex_tool_permission_prompt",
        "password_manager_unlock_prompt",
        "MFA_prompt_outside_approved_handoff"
      ],
      "hard_block": [
        "account_security_change",
        "password_change",
        "payment_prompt",
        "identity_verification",
        "credential_export",
        "cookie_or_token_export",
        "Level_5_protected_action"
      ]
    },
    "protected_final_actions_require_pause_or_approval": [
      "sending_messages",
      "submitting_forms",
      "purchasing",
      "deleting_important_files",
      "changing_account_or_security_settings",
      "publishing",
      "deploying",
      "sharing_private_information"
    ],
    "private_testing_artifacts_must_stay_ignored": [
      "real_credentials",
      "webhook_urls",
      "phone_numbers",
      "account_details",
      "personal_screenshots",
      "browser_session_files",
      "cookies",
      "tokens",
      "traces",
      "private_local_state",
      "real_personal_account_outputs"
    ]
  }
}
