{
  "schema_version": 1,
  "description": "Account-free fixture cases for Coworx real-work, upload fallback, standby, and credential routing regressions.",
  "real_work_completion": [
    {
      "name": "completed_local_file_has_artifact_and_evidence",
      "expect": "pass",
      "request": "Create a local summary file from the supplied notes.",
      "result": {
        "status": "completed",
        "summary": "Created the requested local summary.",
        "outputs": [
          { "type": "file", "path": "outputs/demo/summary.md" }
        ],
        "evidence": [
          { "type": "path", "value": "outputs/demo/summary.md" },
          { "type": "check", "value": "rendered and inspected" }
        ]
      }
    },
    {
      "name": "plan_only_claimed_completion_is_rejected",
      "expect": "fail",
      "request": "Organize the supplied local files and produce the final manifest.",
      "result": {
        "status": "completed",
        "summary": "Here is the plan: create a manifest, move the files, then verify the result.",
        "outputs": [],
        "evidence": []
      }
    }
  ],
  "upload_file_picker_fallback": [
    {
      "name": "file_picker_block_stages_concrete_review_point",
      "expect": "pass",
      "request": "Upload the generated report to the approved portal.",
      "result": {
        "status": "staged",
        "summary": "The report was generated and the upload is staged at the file picker.",
        "outputs": [
          { "type": "file", "path": "outputs/demo/report.pdf" }
        ],
        "evidence": [
          { "type": "path", "value": "outputs/demo/report.pdf" },
          { "type": "staged_state", "value": "file picker open with report selected" }
        ],
        "staged_actions": [
          {
            "type": "upload_review",
            "target": "approved portal",
            "source": "outputs/demo/report.pdf",
            "reason": "GUI file picker needs user review before final submit"
          }
        ]
      }
    },
    {
      "name": "file_picker_block_without_artifact_or_stage_is_rejected",
      "expect": "fail",
      "request": "Upload the generated report to the approved portal.",
      "result": {
        "status": "blocked",
        "summary": "I could not use the file picker. You can upload the file manually.",
        "outputs": [],
        "evidence": [],
        "staged_actions": []
      }
    }
  ],
  "download_then_fanout": [
    {
      "name": "signed_in_export_is_processed_from_local_shards",
      "expect": "pass",
      "request": "Use the approved signed in site to summarize a large assignment list.",
      "result": {
        "status": "completed",
        "privacy_classification": "signed-in-account-private",
        "extraction": {
          "used": true,
          "tool": "computer_use",
          "source_artifact_path": ".coworx-private/outputs/schoology/calendar-export.html",
          "artifact_verified": true,
          "verification_method": "filename_and_size",
          "gui_locks_released_before_fanout": true
        },
        "fanout": {
          "used": true,
          "shard_key": "course",
          "shards_created": 4,
          "local_lanes_started": 4,
          "online_processing_after_download": false
        },
        "outputs": [
          { "type": "local_state", "path": ".coworx-private/outputs/schoology/rundown.md" }
        ],
        "evidence": [
          { "type": "path", "value": ".coworx-private/outputs/schoology/calendar-export.html" },
          { "type": "check", "value": "artifact verified before fanout" },
          { "type": "check", "value": "four local shard results integrated" }
        ]
      }
    },
    {
      "name": "single_online_operator_processing_large_site_is_rejected",
      "expect": "fail",
