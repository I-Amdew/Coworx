        "extraction": {
          "used": false,
          "tool": "computer_use",
          "source_artifact_path": "",
          "artifact_verified": false,
          "verification_method": "",
          "gui_locks_released_before_fanout": false
        },
        "fanout": {
          "used": false,
          "shard_key": "",
          "shards_created": 0,
          "local_lanes_started": 0,
          "online_processing_after_download": true
        },
        "outputs": [
          { "type": "local_state", "path": ".coworx-private/outputs/schoology/rundown.md" }
        ],
        "evidence": [
          { "type": "check", "value": "one GUI lane read every page online" }
        ]
      }
    }
  ],
